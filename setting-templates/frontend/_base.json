{
  "stack": "frontend",
  "description": "Plugins shared regardless of frontend framework: TypeScript language intelligence, UI-design guidance, browser E2E testing, accessibility auditing.",
  "merge": {
    "enabledPlugins": {
      "typescript-lsp@claude-plugins-official": true,
      "frontend-design@claude-plugins-official": true,
      "playwright@claude-plugins-official": true,
      "accesslint@accesslint": true
    }
  },
  "plugins": [
    {
      "id": "typescript-lsp@claude-plugins-official",
      "description": "TypeScript/JavaScript language server for enhanced code intelligence.",
      "check": {
        "installed_file": "~/.claude/plugins/installed_plugins.json",
        "cmd": "claude plugin list",
        "bash": "jq -e '.plugins[\"typescript-lsp@claude-plugins-official\"]' ~/.claude/plugins/installed_plugins.json >/dev/null 2>&1 && echo INSTALLED || echo MISSING",
        "slash": "/plugin list"
      },
      "install": {
        "marketplace_add": {
          "cmd": "claude plugin marketplace add anthropics/claude-plugins-official",
          "slash": "/plugin marketplace add anthropics/claude-plugins-official"
        },
        "cmd": "claude plugin install typescript-lsp@claude-plugins-official --scope project",
        "bash": "claude plugin install typescript-lsp@claude-plugins-official --scope project",
        "slash": "/plugin install typescript-lsp@claude-plugins-official"
      }
    },
    {
      "id": "frontend-design@claude-plugins-official",
      "description": "Guidance for distinctive, intentional UI visual design (typography, aesthetic direction, non-templated choices). Anthropic-authored, free.",
      "check": {
        "installed_file": "~/.claude/plugins/installed_plugins.json",
        "cmd": "claude plugin list",
        "bash": "jq -e '.plugins[\"frontend-design@claude-plugins-official\"]' ~/.claude/plugins/installed_plugins.json >/dev/null 2>&1 && echo INSTALLED || echo MISSING",
        "slash": "/plugin list"
      },
      "install": {
        "marketplace_add": {
          "cmd": "claude plugin marketplace add anthropics/claude-plugins-official",
          "slash": "/plugin marketplace add anthropics/claude-plugins-official"
        },
        "cmd": "claude plugin install frontend-design@claude-plugins-official --scope project",
        "bash": "claude plugin install frontend-design@claude-plugins-official --scope project",
        "slash": "/plugin install frontend-design@claude-plugins-official"
      }
    },
    {
      "id": "playwright@claude-plugins-official",
      "description": "Browser automation / E2E testing (Microsoft Playwright, MIT, free).",
      "check": {
        "installed_file": "~/.claude/plugins/installed_plugins.json",
        "cmd": "claude plugin list",
        "bash": "jq -e '.plugins[\"playwright@claude-plugins-official\"]' ~/.claude/plugins/installed_plugins.json >/dev/null 2>&1 && echo INSTALLED || echo MISSING",
        "slash": "/plugin list"
      },
      "install": {
        "marketplace_add": {
          "cmd": "claude plugin marketplace add anthropics/claude-plugins-official",
          "slash": "/plugin marketplace add anthropics/claude-plugins-official"
        },
        "cmd": "claude plugin install playwright@claude-plugins-official --scope project",
        "bash": "claude plugin install playwright@claude-plugins-official --scope project",
        "slash": "/plugin install playwright@claude-plugins-official"
      }
    },
    {
      "id": "accesslint@accesslint",
      "description": "WCAG 2.1 AA accessibility auditor/refactor agent + contrast-checker skill. Third-party (github.com/accesslint/claude-marketplace, MIT, ~24 stars as of this writing - modest adoption but a real, actively-maintained, genuinely free single-purpose plugin; bundled MCP server is a local npm package, no paid API calls).",
      "check": {
        "installed_file": "~/.claude/plugins/installed_plugins.json",
        "cmd": "claude plugin list",
        "bash": "jq -e '.plugins[\"accesslint@accesslint\"]' ~/.claude/plugins/installed_plugins.json >/dev/null 2>&1 && echo INSTALLED || echo MISSING",
        "slash": "/plugin list"
      },
      "install": {
        "marketplace_add": {
          "cmd": "claude plugin marketplace add accesslint/claude-marketplace",
          "slash": "/plugin marketplace add accesslint/claude-marketplace"
        },
        "cmd": "claude plugin install accesslint@accesslint --scope project",
        "bash": "claude plugin install accesslint@accesslint --scope project",
        "slash": "/plugin install accesslint@accesslint"
      }
    }
  ]
}
