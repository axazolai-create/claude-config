{
  "stack": "kotlin",
  "description": "Generic Kotlin/JVM projects (backend/Ktor/CLI/etc), not specifically mobile - a real Android app also matches this and additionally gets 'android' (mobile/android.json); both firing together is fine, the plugin id is deduplicated.",
  "merge": {
    "enabledPlugins": {
      "kotlin-lsp@claude-plugins-official": true
    }
  },
  "plugins": [
    {
      "id": "kotlin-lsp@claude-plugins-official",
      "description": "Kotlin language server for code intelligence.",
      "check": {
        "installed_file": "~/.claude/plugins/installed_plugins.json",
        "cmd": "claude plugin list",
        "bash": "jq -e '.plugins[\"kotlin-lsp@claude-plugins-official\"]' ~/.claude/plugins/installed_plugins.json >/dev/null 2>&1 && echo INSTALLED || echo MISSING",
        "slash": "/plugin list"
      },
      "install": {
        "marketplace_add": {
          "cmd": "claude plugin marketplace add anthropics/claude-plugins-official",
          "slash": "/plugin marketplace add anthropics/claude-plugins-official"
        },
        "cmd": "claude plugin install kotlin-lsp@claude-plugins-official --scope project",
        "bash": "claude plugin install kotlin-lsp@claude-plugins-official --scope project",
        "slash": "/plugin install kotlin-lsp@claude-plugins-official"
      }
    }
  ]
}
