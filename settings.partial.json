{
  "_comment": "Reference only. Prefer `node setup.mjs` (merges these keys into your existing ~/.claude/settings.json and fills absolute paths). Manual merge: ADD these keys, keep your model/enabledPlugins/language. Replace <HOME> with your real home dir (Linux/macOS: /home/you ; Windows JSON: C:\\\\Users\\\\you). NOTE: no global claudeMdExcludes here on purpose — .planning/CLAUDE.md may be your curated file. If a specific project's .planning/CLAUDE.md is GSD-owned and unwanted at load, add  \"claudeMdExcludes\": [\"**/.planning/CLAUDE.md\"]  to THAT project's .claude/settings.json only.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/deny-curated-claude-md.mjs"] }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/secrets-gate.mjs"] }
        ]
      },
      {
        "matcher": "Bash|^mcp__.*",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/db-live-access-gate.mjs"] }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/graphify-global-sync.mjs"] }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/gsd-config-patch.mjs"] }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/token-usage-log.mjs"] }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/token-usage-log.mjs"] }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "node", "args": ["<HOME>/.claude/hooks/session-init.mjs"] }
        ]
      }
    ]
  },
  "permissions": {
    "deny": ["Edit(~/.claude/CLAUDE.md)", "Write(~/.claude/CLAUDE.md)", "MultiEdit(~/.claude/CLAUDE.md)"]
  }
}
